# Web LLM Proxy configuration
# Copy this file to .env and adjust as needed.

HOST=127.0.0.1
PORT=8080

# Set to false to open a visible browser (useful for debugging selectors or initial login)
HEADLESS=true

# Default site for /v1/messages (Anthropic-compatible endpoint used by Claude Code)
# Must match the `name:` field in one of the proxy/sites/*.yaml files
USE_AI_URL=https://use.ai

# Path to the cookie file for the default /v1/messages site
# COOKIES_PATH=data/cookies/use-ai.json

# Response detection tuning
POLL_INTERVAL_MS=200       # how often to check if response is done (ms)
STABLE_THRESHOLD_MS=1500   # text must be unchanged this long before declaring done (ms)
RESPONSE_TIMEOUT_S=120     # hard timeout per request (seconds)
